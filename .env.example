# Postgres（docker-compose 同时用作 backend 的 DB 连接参数）
POSTGRES_USER=upstreamhub
POSTGRES_PASSWORD=
POSTGRES_DB=upstreamhub
# 宿主机映射端口；容器内仍是 5432
POSTGRES_PORT=54329

# 前端对外端口（容器内 backend 仍是 8418，nginx 已下线，前端直接由 Go 嵌入 serve）
UPSTREAMHUB_HTTP_PORT=8080

# Backend 运行模式 / 日志等级（compose 已把数据库参数写死指向 postgres 容器，
# 想本地直跑 go run 时再用 UPSTREAMHUB_DATABASE_HOST 等覆盖）
UPSTREAMHUB_SERVER_MODE=release
UPSTREAMHUB_LOG_LEVEL=info

# 当前部署对应的 GitHub 仓库，用于右上角链接和版本检查。
UPSTREAMHUB_REPOSITORY=csbsgyl/upstream-hub

# 采集频率（6 字段 cron，含秒）。默认每 5 分钟同一轮同步余额和倍率。
# 如需回到旧的分开采集，可清空 SYNC_CRON，再单独设置 BALANCE_CRON / RATE_CRON。
UPSTREAMHUB_SCHEDULER_SYNC_CRON="37 */5 * * * *"
UPSTREAMHUB_SCHEDULER_BALANCE_CRON=
UPSTREAMHUB_SCHEDULER_RATE_CRON=

# 主密钥（任意长度，至少 32 字节随机串），用于 AES-GCM 加密敏感字段。
# **必填** — 修改后既有数据无法解密，请务必妥善保存。
APP_SECRET=

# 鉴权开关。默认 true = 访问需要登录。
# 默认账号 admin / admin，首次登录会强制要求修改密码（凭据存数据库，bcrypt 哈希）。
# 纯内网 / 反代后面想免登录可设 AUTH_ENABLED=false。
AUTH_ENABLED=true

# Seed 用的默认管理员账号 / 密码（仅在 admin_users 表为空时生效）。
# ADMIN_PASSWORD 留空 → 播种 admin/admin 且首登强制改密（推荐，最省事）。
# ADMIN_PASSWORD 填了强密码 → 用它播种，无需首登改密。
ADMIN_USERNAME=admin
ADMIN_PASSWORD=

# token 签名密钥；留空时回退使用 APP_SECRET
AUTH_TOKEN_SECRET=

# 倍率变动通知策略。默认全部通知；这些只影响推送，不影响 rate_change_logs 历史记录。
UPSTREAMHUB_NOTIFICATIONS_BATCH_RATE_CHANGES=true
UPSTREAMHUB_NOTIFICATIONS_MIN_CHANGE_PCT=0
# all / increase / decrease
UPSTREAMHUB_NOTIFICATIONS_RATE_CHANGE_DIRECTION=all
# 逗号分隔，例如：free,gpt-4o-mini。留空表示不静默任何分组。
UPSTREAMHUB_NOTIFICATIONS_RATE_CHANGE_QUIET_GROUPS=
UPSTREAMHUB_NOTIFICATIONS_BALANCE_LOW_COOLDOWN_MINUTES=60
UPSTREAMHUB_NOTIFICATIONS_FAILURE_COOLDOWN_MINUTES=10
# 默认 1 次，避免通知接口已收到但客户端超时后重试导致重复通知；确认需要网络重试时再调高。
UPSTREAMHUB_NOTIFICATIONS_SEND_MAX_ATTEMPTS=1
